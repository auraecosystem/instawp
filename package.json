{
  "name": "@instawp/cli",
  "version": "0.0.1-beta.5",
  "description": "InstaWP CLI - Create and manage WordPress sites from the terminal",
  "type": "module",
  "bin": {
    "instawp": "./dist/index.js"
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "scripts/mysql2sqlite",
    "bin/win32/**",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "instawp",
    "wordpress",
    "wp-cli",
    "cli",
    "hosting",
    "devtools"
  ],
  "homepage": "https://github.com/InstaWP/cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InstaWP/cli.git"
  },
  "bugs": {
    "url": "https://github.com/InstaWP/cli/issues"
  },
  "author": "InstaWP <vikas@instawp.com>",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "open": "^10.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  }
}
